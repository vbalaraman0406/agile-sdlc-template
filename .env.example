# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# Application
APP_NAME=
APP_ENV=development
APP_PORT=3000
APP_LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# Authentication
JWT_SECRET=
JWT_EXPIRY=3600

# External APIs
# API_KEY=
